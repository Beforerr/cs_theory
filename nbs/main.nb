    RowBox[{"n", "[", "zmax", "]"}], "==", 
    RowBox[{"1", "+", "eps"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bc3", "=", 
    RowBox[{
     RowBox[{"Bx", "[", "zmax", "]"}], "==", 
     RowBox[{"1", "-", "eps"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Manipulate", "[", "\n", 
  RowBox[{"(*", 
