      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"n", "[", "z", "]"}]}], ")"}]}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"gamma", "=", 
   RowBox[{"5", "/", "3"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"zmax", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
