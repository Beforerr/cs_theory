        SubscriptBox["n", "2"], "->", "n2"}], ",", 
       RowBox[{
        SubscriptBox["\[CapitalGamma]", "1"], "->", "1"}], ",", 
       RowBox[{
        SubscriptBox["\[CapitalGamma]", "2"], "->", 
        RowBox[{"-", "1"}]}]}], "}"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"n1", ",", "n2"}], "}"}], ",", "z"}], 
   "]"}]}], "\[IndentingNewLine]", 
