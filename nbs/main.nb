    RowBox[{
     RowBox[{"By", "[", "z", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"n", "[", "z", "]"}], "-", "1"}], ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
