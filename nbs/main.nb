          RowBox[{"Bx", "[", "z", "]"}], ",", 
          RowBox[{"By", "[", "z", "]"}], ",", 
          RowBox[{"ux", "[", "z", "]"}], ",", 
          RowBox[{"uy", "[", "z", "]"}], ",", 
          RowBox[{"n", "[", "z", "]"}], ",", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"Bx", "[", "z", "]"}], ")"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"By", "[", "z", "]"}], ")"}], "2"]}], "]"}]}], "}"}], "/.",
         " ", "sol"}], "]"}], ",", 
      RowBox[{"{", 
