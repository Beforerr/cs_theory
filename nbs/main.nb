        RowBox[{"n", "[", "z", "]"}], ",", "z"}], "]"}], "==", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"n", "[", "z", "]"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"ux", "[", "z", "]"}], " ", 
