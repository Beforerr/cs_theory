Cell[BoxData[{
 RowBox[{
  RowBox[{"num", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rule3", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["m", "\[Alpha]_"], ":>", "1"}], ",", 
     RowBox[{"e", "->", "1"}], ",", 
     RowBox[{
      SubscriptBox["C", "\[Alpha]_"], ":>", "1"}], ",", 
     RowBox[{"\[Gamma]", "->", 
      RowBox[{"5", "/", "3"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq1", "[", "\[Alpha]_", "]"}], ":=", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        SubscriptBox["m", "\[Alpha]"], 
        SuperscriptBox[
         SubscriptBox["\[CapitalGamma]", "\[Alpha]"], "2"]}], 
       RowBox[{
        SubscriptBox["n", "\[Alpha]"], "[", "z", "]"}]], "+", 
      RowBox[{
       SubscriptBox["C", "\[Alpha]"], 
       SuperscriptBox[
        RowBox[{
         SubscriptBox["n", "\[Alpha]"], "[", "z", "]"}], "\[Gamma]"]}]}], ",",
      "z"}], "]"}], "==", 
   RowBox[{
    RowBox[{"-", "e"}], " ", 
    RowBox[{
     SubscriptBox["n", "\[Alpha]"], "[", "z", "]"}], " ", "Te", " ", 
    FractionBox[
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["n", "i"], "[", "z", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "num"}], "}"}]}], "]"}], ",", "z"}], "]"}], 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        SubscriptBox["n", "i"], "[", "z", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "num"}], "}"}]}], 
      "]"}]]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"eqs", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"eq1", "[", "1", "]"}], "/.", "rule3"}], ",", 
    RowBox[{
     RowBox[{"eq1", "[", "2", "]"}], "/.", "rule3"}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["n", "1"], "[", "30", "]"}], "==", "1"}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["n", "2"], "[", "30", "]"}], "==", "2"}]}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"sol", "=", 
  RowBox[{"DSolve", "[", 
   RowBox[{
    RowBox[{"eqs", "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SubscriptBox["n", "1"], "->", "n1"}], ",", 
